<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><title>房型管理</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css"></head><body>
<div class="top"><h2>房型管理</h2><a href="${pageContext.request.contextPath}/admin/logout">退出</a></div><div class="wrap"><div class="nav"><a href="${pageContext.request.contextPath}/admin/orders">订单</a><a href="${pageContext.request.contextPath}/admin/roomTypes">房型</a><a href="${pageContext.request.contextPath}/admin/rooms">房间</a><a href="${pageContext.request.contextPath}/admin/users">用户</a></div>
<div class="panel"><form class="row" method="post" action="${pageContext.request.contextPath}/admin/roomTypes/save"><label>房型名称<input name="typeName" required></label><label>图片地址<input name="imageUrl"></label><label>价格<input name="price" required></label><label>床型<input name="bedType"></label><label>可住人数<input name="capacity" value="2"></label><label>早餐<input name="breakfast" value="含早餐"></label><label>设施<input name="facilities"></label><label>状态<select name="status"><option value="1">上架</option><option value="0">下架</option></select></label><button class="btn">新增房型</button></form></div>
<table><tr><th>名称</th><th>价格</th><th>床型</th><th>人数</th><th>状态</th><th>操作</th></tr><c:forEach items="${roomTypes}" var="r"><tr><td>${r.typeName}</td><td>￥${r.price}</td><td>${r.bedType}</td><td>${r.capacity}</td><td>${r.status==1?'上架':'下架'}</td><td><a class="btn gray" href="${pageContext.request.contextPath}/admin/roomTypes/status?id=${r.id}&status=${r.status==1?0:1}">上下架</a> <a class="btn red" href="${pageContext.request.contextPath}/admin/roomTypes/delete?id=${r.id}">删除</a></td></tr></c:forEach></table>
</div></body></html>
