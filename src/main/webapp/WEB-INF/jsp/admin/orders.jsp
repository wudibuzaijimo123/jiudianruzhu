<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><title>订单管理</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css"></head><body>
<div class="top"><h2>订单管理</h2><a href="${pageContext.request.contextPath}/admin/logout">退出</a></div><div class="wrap"><div class="nav"><a href="${pageContext.request.contextPath}/admin/orders">订单</a><a href="${pageContext.request.contextPath}/admin/roomTypes">房型</a><a href="${pageContext.request.contextPath}/admin/rooms">房间</a><a href="${pageContext.request.contextPath}/admin/users">用户</a></div>
<div class="panel"><form class="row" method="get"><label>关键词<input name="keyword" value="${keyword}" placeholder="订单号/手机号/入住人"></label><label>状态<select name="status"><option value="">全部</option><option value="BOOKED">已预定</option><option value="CHECKED_IN">已入住</option><option value="COMPLETED">已完成</option><option value="CANCELED">已取消</option></select></label><button class="btn">检索</button></form></div>
<table><tr><th>订单号</th><th>用户</th><th>房型</th><th>房间</th><th>入住人</th><th>日期</th><th>金额</th><th>状态</th><th>操作</th></tr>
<c:forEach items="${orders}" var="o"><tr><td>${o.orderNo}</td><td>${o.username}/${o.userPhone}</td><td>${o.typeName}</td><td>${o.roomNo}</td><td>${o.guestName}</td><td>${o.checkinDate} 至 ${o.checkoutDate}</td><td>￥${o.totalAmount}</td><td>${o.status}</td><td><c:if test="${o.status=='BOOKED'}"><a class="btn blue" href="${pageContext.request.contextPath}/admin/orders/checkin?id=${o.id}">入住</a> <a class="btn red" href="${pageContext.request.contextPath}/admin/orders/cancel?id=${o.id}">取消</a></c:if><c:if test="${o.status=='CHECKED_IN'}"><a class="btn" href="${pageContext.request.contextPath}/admin/orders/checkout?id=${o.id}">退房</a></c:if></td></tr></c:forEach>
</table></div></body></html>
