<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!doctype html><html><head><title>房间管理</title><link rel="stylesheet" href="${pageContext.request.contextPath}/static/css/style.css"></head><body>
<div class="top"><h2>房间管理</h2><a href="${pageContext.request.contextPath}/admin/logout">退出</a></div><div class="wrap"><div class="nav"><a href="${pageContext.request.contextPath}/admin/orders">订单</a><a href="${pageContext.request.contextPath}/admin/roomTypes">房型</a><a href="${pageContext.request.contextPath}/admin/rooms">房间</a><a href="${pageContext.request.contextPath}/admin/users">用户</a></div>
<div class="panel"><form class="row" method="post" action="${pageContext.request.contextPath}/admin/rooms/save"><label>房型<select name="roomTypeId"><c:forEach items="${roomTypes}" var="rt"><option value="${rt.id}">${rt.typeName}</option></c:forEach></select></label><label>房间号<input name="roomNo" required></label><label>楼层<input name="floorNo"></label><label>状态<select name="status"><option value="FREE">空闲</option><option value="CLEANING">清洁中</option><option value="REPAIR">维修中</option></select></label><button class="btn">新增房间</button></form></div>
<table><tr><th>房间号</th><th>房型</th><th>楼层</th><th>状态</th><th>操作</th></tr><c:forEach items="${rooms}" var="r"><tr><td>${r.roomNo}</td><td>${r.typeName}</td><td>${r.floorNo}</td><td>${r.status}</td><td><a class="btn" href="${pageContext.request.contextPath}/admin/rooms/status?id=${r.id}&status=FREE">空闲</a> <a class="btn gray" href="${pageContext.request.contextPath}/admin/rooms/status?id=${r.id}&status=CLEANING">清洁</a> <a class="btn red" href="${pageContext.request.contextPath}/admin/rooms/status?id=${r.id}&status=REPAIR">维修</a> <a class="btn red" href="${pageContext.request.contextPath}/admin/rooms/delete?id=${r.id}">删除</a></td></tr></c:forEach></table>
</div></body></html>
